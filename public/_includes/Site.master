<%@ Master Language="C#" AutoEventWireup="true" %>

<!DOCTYPE html>
<html lang="en">
<head runat="server">
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title><asp:ContentPlaceHolder ID="TitleContent" runat="server">ORIC - Office of Research, Innovation &amp; Commercialization</asp:ContentPlaceHolder></title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;600;700&family=Merriweather:wght@700&display=swap" rel="stylesheet" />

    <!-- Tailwind CSS -->
    <link href="<%= ResolveUrl("~/assets/css/site.css") %>" rel="stylesheet" />

    <!-- Page-specific head content -->
    <asp:ContentPlaceHolder ID="HeadContent" runat="server"></asp:ContentPlaceHolder>

    <style>
        /* ── CSS VARIABLES ─────────────────────────────── */
        :root {
            --gov-navy:   #1a3a5c;
            --gov-blue:   #1e5799;
            --gov-accent: #c8102e;
            --gov-gold:   #f0a500;
            --gov-light:  #f4f7fb;
            --gov-border: #dce4ef;
            --gov-text:   #1a2733;
            --gov-muted:  #5a6e82;
            --white:      #ffffff;
            --shadow:     0 2px 16px rgba(26,58,92,0.13);
        }

        *, *::before, *::after { box-sizing: border-box; }
        body { font-family: 'Source Sans 3', sans-serif; }

        /* ── TOP UTILITY STRIP ─────────────────────────── */
        .top-strip {
            background: var(--gov-navy);
            color: #b8cfea;
            font-size: 12px;
            padding: 6px 0;
        }
        .top-strip .ts-inner {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
        }
        .top-strip a { color: #b8cfea; text-decoration: none; transition: color .2s; }
        .top-strip a:hover { color: var(--gov-gold); }
        .ts-links { display: flex; gap: 14px; align-items: center; }
        .ts-links span { color: #4a6a8a; }

        /* ── BRAND BAR ─────────────────────────────────── */
        .brand-bar {
            background: var(--white);
            border-bottom: 3px solid var(--gov-accent);
            box-shadow: var(--shadow);
        }
        .brand-bar .bb-inner {
            max-width: 1280px;
            margin: 0 auto;
            padding: 12px 24px;
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .brand-logo { height: 68px; width: auto; display: block; }
        .brand-text { flex: 1; min-width: 0; }
        .brand-text h1 {
            font-family: 'Merriweather', serif;
            font-size: clamp(15px, 2vw, 20px);
            color: var(--gov-navy);
            line-height: 1.25;
        }
        .brand-text p {
            font-size: 13px;
            color: var(--gov-muted);
            margin-top: 3px;
        }
        .brand-badges { display: flex; gap: 8px; flex-shrink: 0; }
        .badge {
            font-size: 11px; font-weight: 700; letter-spacing: .6px;
            padding: 4px 10px; border-radius: 3px; text-transform: uppercase;
        }
        .badge-hec { background: #003087; color: #fff; }
        .badge-pk  { background: var(--gov-accent); color: #fff; }

        /* ── STICKY NAV ────────────────────────────────── */
        .main-nav {
            background: var(--gov-blue);
            position: sticky;
            top: 0;
            z-index: 500;
            box-shadow: 0 3px 10px rgba(0,0,0,0.22);
        }
        .nav-inner {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 24px;
            display: flex;
            align-items: stretch;
        }

        /* Desktop nav items */
        .desktop-nav { display: flex; align-items: stretch; }
        .nav-item { position: relative; }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 5px;
            padding: 0 16px;
            height: 50px;
            color: rgba(255,255,255,.92);
            font-size: 13.5px;
            font-weight: 600;
            text-decoration: none;
            white-space: nowrap;
            letter-spacing: .3px;
            transition: background .2s, color .2s;
            cursor: pointer;
            background: none;
            border: none;
            font-family: inherit;
        }
        .nav-link:hover,
        .nav-item:hover > .nav-link { background: rgba(255,255,255,.12); color: #fff; }
        .nav-link.active { background: var(--gov-accent); color: #fff; }

        .nav-link .caret {
            width: 10px; height: 10px;
            transition: transform .25s; flex-shrink: 0;
        }
        .nav-item:hover > .nav-link .caret { transform: rotate(180deg); }

        /* Dropdown */
        .dropdown {
            position: absolute;
            top: 100%; left: 0;
            min-width: 230px;
            background: var(--white);
            border-top: 3px solid var(--gov-accent);
            box-shadow: 0 8px 30px rgba(0,0,0,0.18);
            border-radius: 0 0 6px 6px;
            display: none;
            z-index: 600;
            animation: dropIn .18s ease;
        }
        @keyframes dropIn {
            from { opacity: 0; transform: translateY(-6px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .nav-item:hover .dropdown { display: block; }

        .dd-section { padding: 6px 0; border-bottom: 1px solid var(--gov-border); }
        .dd-section:last-child { border-bottom: none; }

        .dd-label {
            display: block;
            padding: 6px 16px 3px;
            font-size: 10px; font-weight: 700;
            text-transform: uppercase; letter-spacing: 1px;
            color: var(--gov-muted);
        }
        .dropdown a {
            display: flex; align-items: center; gap: 8px;
            padding: 9px 16px;
            font-size: 13.5px; color: var(--gov-text);
            text-decoration: none;
            transition: background .15s, padding-left .15s, color .15s;
        }
        .dropdown a:hover {
            background: var(--gov-light);
            color: var(--gov-blue);
            padding-left: 22px;
        }

        /* Search button */
        .nav-search-btn {
            margin-left: auto;
            display: flex; align-items: center;
            height: 50px; padding: 0 16px;
            background: none; border: none;
            color: rgba(255,255,255,.75);
            cursor: pointer; transition: color .2s;
        }
        .nav-search-btn:hover { color: #fff; }
        .nav-search-btn svg { width: 18px; height: 18px; }

        /* Mobile toggle */
        .mobile-toggle {
            display: none;
            margin-left: auto;
            align-items: center;
            height: 50px; padding: 0 16px;
            background: none; border: none;
            color: #fff; cursor: pointer;
        }
        .mobile-toggle svg { width: 24px; height: 24px; }

        /* ── MOBILE MENU ────────────────────────────────── */
        .mobile-nav {
            display: none;
            background: var(--gov-navy);
            overflow: hidden;
            max-height: 0;
            transition: max-height .35s ease;
        }
        .mobile-nav.open { max-height: 100vh; }
        .mobile-nav-inner { padding: 8px 0 16px; }

        .m-link {
            display: flex; align-items: center;
            justify-content: space-between;
            width: 100%; padding: 13px 24px;
            color: rgba(255,255,255,.9);
            font-size: 14px; font-weight: 600;
            text-decoration: none;
            background: none; border: none;
            border-bottom: 1px solid rgba(255,255,255,.06);
            font-family: inherit; text-align: left;
            cursor: pointer; transition: background .15s;
        }
        .m-link:hover { background: rgba(255,255,255,.08); }
        .m-link svg { width: 14px; height: 14px; flex-shrink: 0; transition: transform .2s; }
        .m-link.expanded svg { transform: rotate(180deg); }

        .m-sub { display: none; background: rgba(0,0,0,.25); }
        .m-sub.open { display: block; }

        .m-sub-label {
            display: block; padding: 8px 24px 3px 38px;
            font-size: 10px; letter-spacing: 1px;
            text-transform: uppercase;
            color: rgba(255,255,255,.35); font-weight: 700;
        }
        .m-sub a {
            display: block; padding: 10px 24px 10px 38px;
            color: rgba(255,255,255,.78); font-size: 13.5px;
            text-decoration: none;
            border-bottom: 1px solid rgba(255,255,255,.04);
            transition: background .15s, color .15s;
        }
        .m-sub a:hover { color: #fff; background: rgba(255,255,255,.07); }

        /* ── FOOTER ─────────────────────────────────────── */
        .site-footer { background: #111827; color: #fff; margin-top: 64px; }
        .footer-inner {
            max-width: 1280px; margin: 0 auto;
            padding: 56px 24px 32px;
        }
        .footer-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 32px;
        }
        .footer-col h3 {
            font-size: 15px; font-weight: 700;
            letter-spacing: .4px; margin-bottom: 16px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--gov-accent);
            display: inline-block;
        }
        .footer-col p, .footer-col li {
            font-size: 13.5px; color: #9ca3af; line-height: 1.7;
        }
        .footer-col ul { list-style: none; padding: 0; margin: 0; }
        .footer-col ul li { margin-bottom: 6px; }
        .footer-col ul li a { color: #9ca3af; text-decoration: none; transition: color .2s; }
        .footer-col ul li a:hover { color: var(--gov-gold); }
        .footer-col .contact-item {
            display: flex; gap: 8px; align-items: flex-start;
            margin-bottom: 8px; color: #9ca3af; font-size: 13.5px;
        }
        .footer-divider {
            border: none; border-top: 1px solid #1f2937;
            margin: 32px 0 24px;
        }
        .footer-bottom {
            display: flex; justify-content: space-between;
            align-items: center; flex-wrap: wrap; gap: 12px;
            font-size: 13px; color: #6b7280;
        }
        .footer-bottom a { color: #6b7280; text-decoration: none; transition: color .2s; }
        .footer-bottom a:hover { color: var(--gov-gold); }

        /* ── RESPONSIVE ─────────────────────────────────── */
        @media (max-width: 1024px) {
            .desktop-nav    { display: none; }
            .mobile-toggle  { display: flex; }
            .nav-search-btn { display: none; }
            .mobile-nav     { display: block; }
            .brand-badges   { display: none; }
            .footer-grid    { grid-template-columns: repeat(2, 1fr); }
        }
        @media (max-width: 600px) {
            .brand-text h1   { font-size: 14px; }
            .brand-text p    { font-size: 12px; }
            .ts-links        { display: none; }
            .footer-grid     { grid-template-columns: 1fr; }
            .footer-bottom   { flex-direction: column; text-align: center; }
        }
    </style>
</head>

<body class="bg-gray-50 min-h-screen flex flex-col">
<form id="form1" runat="server">

    <!-- ══ TOP UTILITY STRIP ══════════════════════════════ -->
    <div class="top-strip">
        <div class="ts-inner">
            <span>Government of Pakistan &nbsp;|&nbsp; Higher Education Commission</span>
            <div class="ts-links">
                <a href="<%= ResolveUrl("~/contact.aspx") %>">Contact</a>
                <span>|</span>
                <a href="<%= ResolveUrl("~/sitemap.aspx") %>">Sitemap</a>
                <span>|</span>
                <a href="#">Accessibility</a>
                <span>|</span>
                <a href="#">&#1575;&#1585;&#1583;&#1608;</a>
            </div>
        </div>
    </div>

    <!-- ══ BRAND BAR ═══════════════════════════════════════ -->
    <div class="brand-bar">
        <div class="bb-inner">
            <img src="<%= ResolveUrl("~/assets/img/Logo.png") %>" alt="ORIC Logo" class="brand-logo" />
            <div class="brand-text">
                <h1>Office of Research, Innovation &amp; Commercialization</h1>
                <p>University of Agriculture Faisalabad &mdash; HEC Recognized ORIC</p>
            </div>
            <div class="brand-badges">
                <span class="badge badge-hec">HEC</span>
                <span class="badge badge-pk">Pakistan</span>
            </div>
        </div>
    </div>

    <!-- ══ MAIN NAV ════════════════════════════════════════ -->
    <nav class="main-nav" role="navigation" aria-label="Main Navigation">
        <div class="nav-inner">

            <!-- DESKTOP NAV -->
            <div class="desktop-nav">

                <!-- Home -->
                <div class="nav-item">
                    <a href="<%= ResolveUrl("~/Default.aspx") %>" class="nav-link active">Home</a>
                </div>

                <!-- About -->
                <div class="nav-item">
                    <button type="button" class="nav-link" aria-haspopup="true" aria-expanded="false">
                        About
                        <svg class="caret" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                            <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                    <div class="dropdown" role="menu">
                        <div class="dd-section">
                            <span class="dd-label">Organization</span>
                            <a href="<%= ResolveUrl("~/about/Organogram.aspx") %>">Organogram</a>
                            <a href="<%= ResolveUrl("~/about/Director.aspx") %>">Director Message</a>
                            <a href="<%= ResolveUrl("~/about/Staff.aspx") %>">Staff</a>
                        </div>
                        <div class="dd-section">
                            <span class="dd-label">Governance</span>
                            <a href="<%= ResolveUrl("~/about/Activities.aspx") %>">Activities</a>
                            <a href="<%= ResolveUrl("~/about/Milestones.aspx") %>">Milestones</a>
                            <a href="<%= ResolveUrl("~/about/IRAB.aspx") %>">IRAB</a>
                            <a href="<%= ResolveUrl("~/about/OSC.aspx") %>">OSC</a>
                            <a href="<%= ResolveUrl("~/about/IFGSJ.aspx") %>">IFGSJ</a>
                        </div>
                    </div>
                </div>

                <!-- Research -->
                <div class="nav-item">
                    <button type="button" class="nav-link" aria-haspopup="true" aria-expanded="false">
                        Research
                        <svg class="caret" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                            <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                    <div class="dropdown" role="menu">
                        <div class="dd-section">
                            <span class="dd-label">Funding &amp; Committees</span>
                            <a href="<%= ResolveUrl("~/research/Funding_Agencies.aspx") %>">Funding Agencies</a>
                            <a href="<%= ResolveUrl("~/research/IBC.aspx") %>">IBC</a>
                            <a href="<%= ResolveUrl("~/research/BEC.aspx") %>">BEC</a>
                        </div>
                        <div class="dd-section">
                            <span class="dd-label">Resources</span>
                            <a href="<%= ResolveUrl("~/research/Services.aspx") %>">Services</a>
                            <a href="<%= ResolveUrl("~/research/Approved_Supervisors.aspx") %>">Approved Supervisors</a>
                            <a href="<%= ResolveUrl("~/research/Professional_Trainings.aspx") %>">Professional Trainings</a>
                            <a href="<%= ResolveUrl("~/research/IMERP.aspx") %>">IMERP</a>
                            <a href="<%= ResolveUrl("~/research/Research_Journals.aspx") %>">Research Journals</a>
                            <a href="<%= ResolveUrl("~/research/OP.aspx") %>">OP</a>
                            <a href="<%= ResolveUrl("~/research/Reimbursements.aspx") %>">Reimbursements</a>
                        </div>
                    </div>
                </div>

                <!-- Outreach -->
                <div class="nav-item">
                    <button type="button" class="nav-link" aria-haspopup="true" aria-expanded="false">
                        Outreach
                        <svg class="caret" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                            <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                    <div class="dropdown" role="menu">
                        <div class="dd-section">
                            <a href="<%= ResolveUrl("~/outreach/Outreach.aspx") %>">Outreach Programs</a>
                            <a href="<%= ResolveUrl("~/outreach/Internships.aspx") %>">Internships</a>
                            <a href="<%= ResolveUrl("~/outreach/Seminars.aspx") %>">Seminars</a>
                        </div>
                    </div>
                </div>

                <!-- Commercialization -->
                <div class="nav-item">
                    <button type="button" class="nav-link" aria-haspopup="true" aria-expanded="false">
                        Commercialization
                        <svg class="caret" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                            <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                    <div class="dropdown" role="menu">
                        <div class="dd-section">
                            <a href="<%= ResolveUrl("~/commercialization/Technologies.aspx") %>">Technologies</a>
                            <a href="<%= ResolveUrl("~/commercialization/Collaboration.aspx") %>">Collaboration</a>
                            <a href="<%= ResolveUrl("~/commercialization/TISC.aspx") %>">TISC</a>
                        </div>
                    </div>
                </div>

                <!-- Media -->
                <div class="nav-item">
                    <button type="button" class="nav-link" aria-haspopup="true" aria-expanded="false">
                        Media
                        <svg class="caret" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                            <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                    <div class="dropdown" role="menu">
                        <div class="dd-section">
                            <a href="<%= ResolveUrl("~/media/News.aspx") %>">News</a>
                            <a href="<%= ResolveUrl("~/media/Gallery.aspx") %>">Gallery</a>
                            <a href="<%= ResolveUrl("~/media/Events.aspx") %>">Events</a>
                            <a href="<%= ResolveUrl("~/media/Documentaries.aspx") %>">Documentaries</a>
                            <a href="<%= ResolveUrl("~/media/Publications.aspx") %>">Publications</a>
                            <a href="<%= ResolveUrl("~/media/Downloads.aspx") %>">Downloads</a>
                        </div>
                    </div>
                </div>

                <!-- Hi-Tech -->
                <div class="nav-item">
                    <button type="button" class="nav-link" aria-haspopup="true" aria-expanded="false">
                        Hi-Tech
                        <svg class="caret" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                            <path d="M2 3.5L5 6.5L8 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                    <div class="dropdown" role="menu">
                        <div class="dd-section">
                            <a href="<%= ResolveUrl("~/Hi-Tech/Diagnostic.aspx") %>">Diagnostic</a>
                            <a href="<%= ResolveUrl("~/Hi-Tech/Training.aspx") %>">Training</a>
                        </div>
                    </div>
                </div>

                <!-- BIC -->
                <div class="nav-item">
                    <a href="<%= ResolveUrl("~/BIC.aspx") %>" class="nav-link">BIC</a>
                </div>

            </div><!-- /desktop-nav -->

            <!-- Search (desktop) -->
            <button type="button" class="nav-search-btn" aria-label="Search" onclick="document.getElementById('searchOverlay').classList.toggle('hidden')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
                </svg>
            </button>

            <!-- Hamburger (mobile) -->
            <button type="button" class="mobile-toggle" id="mobileToggle" aria-label="Toggle navigation menu" onclick="toggleMobileMenu()">
                <svg id="iconMenu" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>

        </div><!-- /nav-inner -->
    </nav>

    <!-- ══ MOBILE NAV ══════════════════════════════════════ -->
    <div class="mobile-nav" id="mobileNav" aria-hidden="true">
