                <a href="<%= ResolveUrl("~/research/IBC.aspx") %>">IBC</a>
                <a href="<%= ResolveUrl("~/research/BEC.aspx") %>">BEC</a>
                <span class="m-sub-label">Resources</span>
                <a href="<%= ResolveUrl("~/research/Services.aspx") %>">Services</a>
                <a href="<%= ResolveUrl("~/research/Approved_Supervisors.aspx") %>">Approved Supervisors</a>
                <a href="<%= ResolveUrl("~/research/Professional_Trainings.aspx") %>">Professional Trainings</a>
                <a href="<%= ResolveUrl("~/research/IMERP.aspx") %>">IMERP</a>
                <a href="<%= ResolveUrl("~/research/Research_Journals.aspx") %>">Research Journals</a>
                <a href="<%= ResolveUrl("~/research/OP.aspx") %>">OP</a>
                <a href="<%= ResolveUrl("~/research/Reimbursements.aspx") %>">Reimbursements</a>
            </div>

            <!-- Outreach mobile -->
            <button type="button" class="m-link" onclick="toggleMobileSub('mSub-outreach', this)" aria-expanded="false">
                Outreach
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="m-sub" id="mSub-outreach" aria-hidden="true">
                <a href="<%= ResolveUrl("~/outreach/Outreach.aspx") %>">Outreach Programs</a>
                <a href="<%= ResolveUrl("~/outreach/Internships.aspx") %>">Internships</a>
                <a href="<%= ResolveUrl("~/outreach/Seminars.aspx") %>">Seminars</a>
            </div>

            <!-- Commercialization mobile -->
            <button type="button" class="m-link" onclick="toggleMobileSub('mSub-comm', this)" aria-expanded="false">
