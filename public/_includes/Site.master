<!-- ══ SCRIPTS ════════════════════════════════════════════ -->
<script src="<%= ResolveUrl("~/assets/js/carousel.js") %>"></script>

<script>
    // ── Mobile menu toggle ─────────────────────────────────
    function toggleMobileMenu() {
        var nav  = document.getElementById('mobileNav');
        var isOpen = nav.classList.contains('open');
        nav.classList.toggle('open');
        nav.setAttribute('aria-hidden', isOpen ? 'true' : 'false');
    }

    // ── Mobile sub-menu accordion ──────────────────────────
    function toggleMobileSub(id, btn) {
        var sub    = document.getElementById(id);
        var isOpen = sub.classList.contains('open');

        // Close all subs first
        document.querySelectorAll('.m-sub').forEach(function(s) {
            s.classList.remove('open');
            s.setAttribute('aria-hidden', 'true');
        });
        document.querySelectorAll('.m-link[aria-expanded]').forEach(function(b) {
            b.classList.remove('expanded');
            b.setAttribute('aria-expanded', 'false');
        });

        if (!isOpen) {
            sub.classList.add('open');
            sub.setAttribute('aria-hidden', 'false');
            btn.classList.add('expanded');
            btn.setAttribute('aria-expanded', 'true');
        }
    }

    // ── Close mobile menu on resize to desktop ─────────────
    window.addEventListener('resize', function() {
        if (window.innerWidth > 1024) {
            var nav = document.getElementById('mobileNav');
            nav.classList.remove('open');
            nav.setAttribute('aria-hidden', 'true');
        }
    });

    // ── Close dropdowns when clicking outside ──────────────
    document.addEventListener('click', function(e) {
        if (!e.target.closest('.main-nav') && !e.target.closest('.mobile-nav')) {
            var nav = document.getElementById('mobileNav');
            if (nav.classList.contains('open')) {
                nav.classList.remove('open');
                nav.setAttribute('aria-hidden', 'true');
            }
        }
    });

    // ── Mark active nav link based on current URL ──────────
    (function() {
        var path = window.location.pathname.toLowerCase();
        document.querySelectorAll('.desktop-nav .nav-link').forEach(function(link) {
            link.classList.remove('active');
        });
        // Home
        if (path === '/' || path.indexOf('default.aspx') !== -1) {
            var homeLink = document.querySelector('.desktop-nav a[href*="Default.aspx"], .desktop-nav a[href*="default.aspx"]');
            if (homeLink) homeLink.classList.add('active');
            return;
        }
        // Match section
        var sections = ['about','research','outreach','commercialization','media','hi-tech','bic'];
        sections.forEach(function(sec) {
            if (path.indexOf('/' + sec + '/') !== -1 || path.indexOf(sec + '.aspx') !== -1) {
                document.querySelectorAll('.desktop-nav .nav-item').forEach(function(item) {
                    var btn = item.querySelector('.nav-link');
                    if (btn && btn.textContent.trim().toLowerCase().replace(/\s+/g,'') === sec.replace('-','')) {
                        btn.classList.add('active');
                    }
                });
            }
        });
    })();
</script>

<asp:ContentPlaceHolder ID="ScriptsContent" runat="server"></asp:ContentPlaceHolder>

</body>
</html>
