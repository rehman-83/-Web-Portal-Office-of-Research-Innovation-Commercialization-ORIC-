            </button>
            <div class="m-sub" id="mSub-media" aria-hidden="true">
                <a href="<%= ResolveUrl("~/media/News.aspx") %>">News</a>
                <a href="<%= ResolveUrl("~/media/Gallery.aspx") %>">Gallery</a>
                <a href="<%= ResolveUrl("~/media/Events.aspx") %>">Events</a>
                <a href="<%= ResolveUrl("~/media/Documentaries.aspx") %>">Documentaries</a>
                <a href="<%= ResolveUrl("~/media/Publications.aspx") %>">Publications</a>
                <a href="<%= ResolveUrl("~/media/Downloads.aspx") %>">Downloads</a>
            </div>

            <!-- Hi-Tech mobile -->
            <button type="button" class="m-link" onclick="toggleMobileSub('mSub-hitech', this)" aria-expanded="false">
                Hi-Tech
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="m-sub" id="mSub-hitech" aria-hidden="true">
                <a href="<%= ResolveUrl("~/Hi-Tech/Diagnostic.aspx") %>">Diagnostic</a>
                <a href="<%= ResolveUrl("~/Hi-Tech/Training.aspx") %>">Training</a>
            </div>

            <a href="<%= ResolveUrl("~/BIC.aspx") %>" class="m-link">BIC</a>

        </div>
    </div><!-- /mobile-nav -->

    <!-- ══ MAIN CONTENT ════════════════════════════════════ -->
    <main class="flex-grow" id="mainContent" role="main">
        <asp:ContentPlaceHolder ID="MainContent" runat="server"></asp:ContentPlaceHolder>
    </main>

    <!-- ══ FOOTER ══════════════════════════════════════════ -->
