            <button type="button" class="m-link" onclick="toggleMobileSub('mSub-about', this)" aria-expanded="false">
                About
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="m-sub" id="mSub-about" aria-hidden="true">
                <span class="m-sub-label">Organization</span>
                <a href="<%= ResolveUrl("~/about/Organogram.aspx") %>">Organogram</a>
                <a href="<%= ResolveUrl("~/about/Director.aspx") %>">Director Message</a>
                <a href="<%= ResolveUrl("~/about/Staff.aspx") %>">Staff</a>
                <span class="m-sub-label">Governance</span>
                <a href="<%= ResolveUrl("~/about/Activities.aspx") %>">Activities</a>
                <a href="<%= ResolveUrl("~/about/Milestones.aspx") %>">Milestones</a>
                <a href="<%= ResolveUrl("~/about/IRAB.aspx") %>">IRAB</a>
                <a href="<%= ResolveUrl("~/about/OSC.aspx") %>">OSC</a>
                <a href="<%= ResolveUrl("~/about/IFGSJ.aspx") %>">IFGSJ</a>
            </div>

            <!-- Research mobile -->
            <button type="button" class="m-link" onclick="toggleMobileSub('mSub-research', this)" aria-expanded="false">
                Research
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="m-sub" id="mSub-research" aria-hidden="true">
                <span class="m-sub-label">Funding &amp; Committees</span>
