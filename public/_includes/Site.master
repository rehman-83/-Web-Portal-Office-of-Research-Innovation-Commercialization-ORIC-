                <a href="<%= ResolveUrl("~/research/IBC.aspx") %>"                   class="block px-6 pl-9 py-2.5 text-[13px] text-blue-200 border-b border-blue-900/30 hover:text-white hover:bg-gov-blue/40 hover:border-l-2 hover:border-l-gov-gold hover:pl-[34px] transition-all duration-150">Institutional Biosafety Committee</a>
