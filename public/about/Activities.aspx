<%@ Page Language="C#" MasterPageFile="~/_includes/Site.master" AutoEventWireup="true" %>

<asp:Content ID="Content1" ContentPlaceHolderID="TitleContent" runat="server">
    ORIC Activities - ORIC
</asp:Content>

<asp:Content ID="Content2" ContentPlaceHolderID="MainContent" runat="server">
    <section class="bg-gradient-to-r from-blue-600 to-blue-800 text-white py-16">
        <div class="container mx-auto px-4">
            <h1 class="text-4xl font-bold mb-4">ORIC Activities</h1>
            <p class="text-xl">Our Key Activities and Programs</p>
        </div>
    </section>
    
    <section class="py-16 bg-white">
        <div class="container mx-auto px-4">
            <div class="max-w-6xl mx-auto">
                <!-- Research Activities -->
                <div class="mb-12">
                    <h2 class="text-3xl font-bold text-gray-900 mb-6">Research Activities</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="card">
                            <h3 class="text-xl font-bold text-blue-600 mb-3">Research Grant Management</h3>
                            <p class="text-gray-700">
                                Facilitation of internal and external research grants, proposal development support, 
                                and monitoring of ongoing research projects.
                            </p>
                        </div>
                        
                        <div class="card">
                            <h3 class="text-xl font-bold text-blue-600 mb-3">Ethical Approvals</h3>
                            <p class="text-gray-700">
                                Processing ethical approvals through IBC and BEC for research involving humans, 
                                animals, and biohazardous materials.
                            </p>
                        </div>
                        
                        <div class="card">
                            <h3 class="text-xl font-bold text-blue-600 mb-3">Research Training</h3>
                            <p class="text-gray-700">
                                Regular workshops and training sessions on research methodology, grant writing, 
                                ethics, and academic publishing.
                            </p>
                        </div>
                        
                        <div class="card">
                            <h3 class="text-xl font-bold text-blue-600 mb-3">Publications Support</h3>
                            <p class="text-gray-700">
                                Assistance with manuscript preparation, journal selection, and support for 
                                publishing in high-impact journals.
                            </p>
                        </div>
                    </div>
                </div>
                
                <!-- Innovation Activities -->
                <div class="mb-12">
                    <h2 class="text-3xl font-bold text-gray-900 mb-6">Innovation & Entrepreneurship</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="card">
                            <h3 class="text-xl font-bold text-blue-600 mb-3">Business Incubation</h3>
                            <p class="text-gray-700">
                                Operating BIC to nurture startups, providing mentorship, workspace, and seed funding 
                                to promising ventures.
                            </p>
                        </div>
                        
                        <div class="card">
                            <h3 class="text-xl font-bold text-blue-600 mb-3">Innovation Competitions</h3>
                            <p class="text-gray-700">
                                Organizing hackathons, idea competitions, and innovation challenges to promote 
                                entrepreneurial thinking.
                            </p>
                        </div>
                        
                        <div class="card">
                            <h3 class="text-xl font-bold text-blue-600 mb-3">Entrepreneurship Training</h3>
                            <p class="text-gray-700">
                                Conducting workshops on business planning, marketing, finance, and IP management 
                                for aspiring entrepreneurs.
                            </p>
                        </div>
                        
                        <div class="card">
                            <h3 class="text-xl font-bold text-blue-600 mb-3">Networking Events</h3>
                            <p class="text-gray-700">
                                Facilitating connections between researchers, industry partners, investors, 
                                and successful entrepreneurs.
                            </p>
                        </div>
                    </div>
                </div>
                
                <!-- Commercialization Activities -->
                <div class="mb-12">
                    <h2 class="text-3xl font-bold text-gray-900 mb-6">Commercialization</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="card">
                            <h3 class="text-xl font-bold text-blue-600 mb-3">Technology Transfer</h3>
                            <p class="text-gray-700">
                                Identifying commercializable research and facilitating technology transfer 
                                to industry partners.
                            </p>
                        </div>
                        
                        <div class="card">
                            <h3 class="text-xl font-bold text-blue-600 mb-3">IP Management</h3>
                            <p class="text-gray-700">
                                Assistance with patent filing, trademark registration, and protection of 
                                intellectual property rights.
                            </p>
                        </div>
                        
                        <div class="card">
                            <h3 class="text-xl font-bold text-blue-600 mb-3">Industry Linkages</h3>
                            <p class="text-gray-700">
                                Building partnerships with industry for collaborative research and technology 
                                commercialization.
                            </p>
                        </div>
                        
                        <div class="card">
                            <h3 class="text-xl font-bold text-blue-600 mb-3">TISC Services</h3>
                            <p class="text-gray-700">
                                Operating Technology & Innovation Support Center for patent search and IP 
                                information services.
                            </p>
                        </div>
                    </div>
                </div>
                
                <!-- Outreach Activities -->
                <div class="mb-12">
                    <h2 class="text-3xl font-bold text-gray-900 mb-6">Outreach & Collaboration</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="card">
                            <h3 class="text-xl font-bold text-blue-600 mb-3">Seminars & Conferences</h3>
                            <p class="text-gray-700">
                                Organizing national and international conferences, seminars, and guest lectures 
                                on research topics.
                            </p>
                        </div>
                        
                        <div class="card">
                            <h3 class="text-xl font-bold text-blue-600 mb-3">International Collaboration</h3>
                            <p class="text-gray-700">
                                Facilitating international research partnerships and exchange programs with 
                                foreign universities.
                            </p>
                        </div>
                        
                        <div class="card">
                            <h3 class="text-xl font-bold text-blue-600 mb-3">Community Engagement</h3>
                            <p class="text-gray-700">
                                Conducting research and innovation activities that address community needs 
                                and societal challenges.
                            </p>
                        </div>
                        
                        <div class="card">
                            <h3 class="text-xl font-bold text-blue-600 mb-3">Internship Programs</h3>
                            <p class="text-gray-700">
                                Coordinating research internships for students with industry and research 
                                organizations.
                            </p>
                        </div>
                    </div>
                </div>
                
                <!-- Annual Events -->
                <div class="bg-blue-50 rounded-lg p-8">
                    <h2 class="text-2xl font-bold text-gray-900 mb-6">Annual Events</h2>
                    <ul class="space-y-3 text-gray-700">
                        <li class="flex items-start space-x-3">
                            <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                            </svg>
                            <span>Annual Research Conference showcasing cutting-edge research from all faculties</span>
                        </li>
                        <li class="flex items-start space-x-3">
                            <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                            </svg>
                            <span>Innovation Expo highlighting technologies and startups from BIC</span>
                        </li>
                        <li class="flex items-start space-x-3">
                            <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                            </svg>
                            <span>Research Week with workshops, seminars, and poster presentations</span>
                        </li>
                        <li class="flex items-start space-x-3">
                            <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                            </svg>
                            <span>Startup Pitch Competition with prizes and investment opportunities</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>
</asp:Content>
